# Awin first-party client — copy this file to tools/awin/.env (gitignored) and fill in.
# Nothing here is sent anywhere except api.awin.com / productdata.awin.com.

# Personal OAuth token — https://ui.awin.com/awin-api → "Show my API token".
# Account-wide; this client only ever GETs (read-only).
AWIN_API_TOKEN="your_awin_oauth_token_here"

# Your publisher account id. Run `awin accounts` to list them. ParkMath = 2932035.
AWIN_PUBLISHER_ID="2932035"

# Optional — only needed for `feed` commands. Awin → Toolbox → Create-a-Feed → API key.
AWIN_FEED_API_KEY=""
