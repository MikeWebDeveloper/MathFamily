# Analytics source for the reel loop digest (tools/reels/src/digest-cli.ts → `pnpm --filter @mathfamily/reels digest`).
# Set ONE source. The digest degrades to a "no analytics yet" report until one is configured.

# Plausible (preferred — exposes the utm_campaign grain the reels are tagged with).
# Self-host is free; cloud is ~$9/mo. Create a read-only API key in Plausible → Settings → API keys.
PLAUSIBLE_HOST=https://plausible.io
PLAUSIBLE_API_KEY=
PLAUSIBLE_SITE_ID=parkmath.co.uk

# OR Cloudflare Web Analytics (path-grain fallback; the digest maps path → reel via the landing URL).
# Web Analytics is the RUM dataset — scoped to ACCOUNT + SITE, not a zone.
#   CF_API_TOKEN    — token with Account Analytics:Read
#   CF_ACCOUNT_TAG  — your Cloudflare Account ID (dash overview → right rail "Account ID")
#   CF_SITE_TAG     — the RUM siteTag dimension (NOT the page's data-cf-beacon token; they differ).
#                     Derive it: query rumPageloadEventsAdaptiveGroups grouped by siteTag and pick the
#                     one whose top requestPaths are your routes.
CF_API_TOKEN=
CF_ACCOUNT_TAG=
CF_SITE_TAG=
